generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id                    String       @id @default(cuid())
  name                  String
  birthDate             DateTime
  expectedLifespanYears Int?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  events                LifeEvent[]
  settings              AppSettings?
}

model LifeEvent {
  id            String   @id @default(cuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date          DateTime
  weekIndex     Int
  category      String
  title         String
  note          String?
  emotionalTone String
  iconKey       String
  colorKey      String
  isPrivate     Boolean  @default(false)
  showOnExport  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([profileId, date])
}

model AppSettings {
  id              String   @id @default(cuid())
  profileId       String   @unique
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  gridDensity     String   @default("comfortable")
  showYearMarkers Boolean  @default(true)
  showWeekNumbers Boolean  @default(false)
  showEventIcons  Boolean  @default(true)
  exportTheme     String   @default("night")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
