{
  "name": "@lifecalendar/api",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name stage2_core_data"
  },
  "dependencies": {
    "@lifecalendar/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^6.8.2",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.8.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
